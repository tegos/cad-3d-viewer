{
    "name": "cad-3d-viewer",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "description": "Drag-drop STEP/IGES CAD files in the browser. Babylon.js + occt-import-js. No backend, no COOP/COEP.",
    "scripts": {
        "dev": "vite",
        "typecheck": "tsc --noEmit",
        "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 vite build",
        "preview": "vite preview"
    },
    "dependencies": {
        "@babylonjs/core": "^7.39.0",
        "@babylonjs/gui": "^7.39.0",
        "@babylonjs/loaders": "^7.39.0",
        "comlink": "^4.4.2",
        "occt-import-js": "0.0.23"
    },
    "devDependencies": {
        "@babylonjs/inspector": "^7.39.0",
        "cross-env": "^7.0.3",
        "ffmpeg-static": "^5.3.0",
        "playwright": "^1.60.0",
        "typescript": "^5.6.3",
        "vite": "^5.4.10",
        "vite-plugin-static-copy": "^2.1.0"
    }
}
